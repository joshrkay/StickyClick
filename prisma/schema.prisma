// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShopSettings {
  id           Int      @id @default(autoincrement())
  shop         String   @unique
  enabled      Boolean  @default(true)
  primaryColor String   @default("#000000")
  textColor    String   @default("#FFFFFF")
  buttonText   String   @default("Add to Cart")
  position     String   @default("BOTTOM_RIGHT") // Keeping as string for SQLite compatibility in MVP
  upsellEnabled Boolean @default(false)
  upsellProductId String? // Shopify GID
  quickBuyEnabled Boolean @default(false)
  showCartSummary Boolean @default(true)
  enableQuantitySelector Boolean @default(true)
  openCartDrawer Boolean @default(true)
  showFreeShippingBar Boolean @default(false)
  freeShippingGoal Int @default(5000) // Default $50.00
  countdownEnabled    Boolean  @default(false)
  countdownEndTime    DateTime?
  countdownDuration   Int      @default(0) // seconds; 0 = disabled
  countdownText       String   @default("Offer ends in")
  trustBadgesEnabled  Boolean  @default(false)
  trustBadgesList     String   @default("secure_checkout,money_back")
  trustBadgesStyle    String   @default("icon_text")
  analyticsEnabled    Boolean  @default(false)
  // Feature 1: Low Stock Urgency
  lowStockEnabled     Boolean  @default(false)
  lowStockThreshold   Int      @default(10)
  // Feature 2: Automatic Discount Display
  showDiscountBadge   Boolean  @default(false)
  // Feature 3: Smart Collection-Based Upsells
  smartUpsellEnabled  Boolean  @default(false)
  smartUpsellStrategy String   @default("same_collection") // same_collection | best_selling | highest_price
  // Feature 4: Multi-Currency / Markets Support
  multiCurrencyEnabled Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ABTest {
  id              Int      @id @default(autoincrement())
  shop            String
  name            String
  status          String   @default("draft") // draft | running | completed
  variantAConfig  String   @db.Text // JSON config for variant A
  variantBConfig  String   @db.Text // JSON config for variant B
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shop, status])
}

model StickyClickEvent {
  id        Int      @id @default(autoincrement())
  shop      String
  eventType String
  variantId String?
  value       Int      @default(0)
  metadata    String?
  testVariant String?  // "A" or "B" for A/B test tracking
  createdAt   DateTime @default(now())

  @@index([shop, eventType, createdAt])
  @@index([shop, createdAt])
}
