# Copy to .env for local dev. On Vercel, set these in Project → Settings → Environment Variables.
# SCOPES must match shopify.app.toml [access_scopes] (comma-separated, no spaces).

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://sticky-click.vercel.app
SCOPES=read_products,write_metafields,read_metafields,write_app_proxy

DATABASE_URL=
