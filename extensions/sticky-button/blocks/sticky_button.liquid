{% schema %}
{
  "name": "Sticky Add To Cart",
  "target": "body",
  "stylesheet": "sticky-button.css",
  "javascript": "sticky-button.js",
  "settings": []
}
{% endschema %}

{%- assign settings = shop.metafields.stickyclick.settings.value -%}
{%- if settings.enabled and product -%}
  <div
    id="sticky-click-container"
    class="sticky-click-hidden"
    data-main-variant-id="{{ product.selected_or_first_available_variant.id }}"
    data-upsell-enabled="{{ settings.upsellEnabled | default: false }}"
    data-upsell-variant-id="{{ settings.upsellProductId | default: '' }}"
    data-quick-buy-enabled="{{ settings.quickBuyEnabled | default: false }}"
    data-show-cart-summary="{{ settings.showCartSummary | default: true }}"
    data-show-free-shipping-bar="{{ settings.showFreeShippingBar | default: false }}"
    data-free-shipping-goal="{{ settings.freeShippingGoal | default: 5000 }}"
    data-enable-quantity-selector="{{ settings.enableQuantitySelector | default: true }}"
    data-open-cart-drawer="{{ settings.openCartDrawer | default: true }}"
    data-position="{{ settings.position | default: 'BOTTOM_RIGHT' }}"
    data-countdown-enabled="{{ settings.countdownEnabled | default: false }}"
    data-countdown-end-time="{{ settings.countdownEndTime | default: '' }}"
    data-countdown-duration="{{ settings.countdownDuration | default: 0 }}"
    data-countdown-text="{{ settings.countdownText | default: 'Offer ends in' | escape }}"
    data-trust-badges-enabled="{{ settings.trustBadgesEnabled | default: false }}"
    data-trust-badges-list="{{ settings.trustBadgesList | default: 'secure_checkout,money_back' }}"
    data-trust-badges-style="{{ settings.trustBadgesStyle | default: 'icon_text' }}"
    data-analytics-enabled="{{ settings.analyticsEnabled | default: false }}"
    data-low-stock-enabled="{{ settings.lowStockEnabled | default: false }}"
    data-low-stock-threshold="{{ settings.lowStockThreshold | default: 10 }}"
    data-inventory-qty="{{ product.selected_or_first_available_variant.inventory_quantity | default: 999 }}"
    data-show-discount-badge="{{ settings.showDiscountBadge | default: false }}"
    data-smart-upsell-enabled="{{ settings.smartUpsellEnabled | default: false }}"
    data-smart-upsell-strategy="{{ settings.smartUpsellStrategy | default: 'same_collection' }}"
    data-multi-currency-enabled="{{ settings.multiCurrencyEnabled | default: false }}"
    data-currency-code="{{ cart.currency.iso_code | default: shop.currency }}"
    data-shop-domain="{{ shop.permanent_domain }}"
    style="
      --sticky-primary: {{ settings.primaryColor | default: '#000000' | remove: ';' | remove: '}' | remove: '{' | truncate: 7, '' }};
      --sticky-text: {{ settings.textColor | default: '#FFFFFF' | remove: ';' | remove: '}' | remove: '{' | truncate: 7, '' }};
    "
  >
    <div class="sticky-click-wrapper">
      {%- if settings.showFreeShippingBar -%}
        <div id="sticky-shipping-bar-container" class="sticky-shipping-bar-hidden">
          <p id="sticky-shipping-text">Free shipping over <span id="sticky-shipping-goal-text"></span></p>
          <div class="sticky-shipping-progress-bg">
            <div id="sticky-shipping-progress-fill" style="width: 0%;"></div>
          </div>
        </div>
      {%- endif -%}

      {%- if settings.countdownEnabled -%}
        <div id="sticky-countdown-container" class="sticky-countdown-hidden">
          <span id="sticky-countdown-label">{{ settings.countdownText | default: 'Offer ends in' | escape }}</span>
          <span id="sticky-countdown-time"></span>
        </div>
      {%- endif -%}

      {%- if settings.trustBadgesEnabled -%}
        <div id="sticky-trust-badges" class="sticky-trust-badges" data-style="{{ settings.trustBadgesStyle | default: 'icon_text' }}">
          {%- assign badges = settings.trustBadgesList | default: 'secure_checkout,money_back' | split: ',' -%}
          {%- for badge in badges -%}
            <span class="sticky-trust-badge" data-badge="{{ badge }}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if settings.lowStockEnabled -%}
        {%- assign inv_qty = product.selected_or_first_available_variant.inventory_quantity -%}
        {%- assign threshold = settings.lowStockThreshold | default: 10 | plus: 0 -%}
        {%- if inv_qty <= threshold and inv_qty > 0 -%}
          <div id="sticky-low-stock-badge" class="sticky-low-stock-badge">
            Only {{ inv_qty }} left!
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- if settings.showDiscountBadge -%}
        <div id="sticky-discount-badge" class="sticky-discount-badge sticky-discount-hidden"></div>
      {%- endif -%}

      {%- if product.selected_or_first_available_variant.available -%}
        {%- if settings.smartUpsellEnabled -%}
          <div id="sticky-smart-upsell" class="sticky-smart-upsell">
            {%- assign current_product_id = product.id -%}
            {%- for collection in product.collections limit: 1 -%}
              {%- for item in collection.products limit: 4 -%}
                {%- if item.id != current_product_id and item.available -%}
                  <div class="sticky-smart-upsell-item" data-variant-id="{{ item.selected_or_first_available_variant.id }}" data-price="{{ item.selected_or_first_available_variant.price }}">
                    {%- if item.featured_image -%}
                      <img src="{{ item.featured_image | image_url: width: 60 }}" alt="{{ item.title | escape }}" width="60" height="60" loading="lazy">
                    {%- endif -%}
                    <div class="sticky-smart-upsell-info">
                      <span class="sticky-smart-upsell-title">{{ item.title | truncate: 30 }}</span>
                      <span class="sticky-smart-upsell-price">{{ item.selected_or_first_available_variant.price | money }}</span>
                    </div>
                    <input type="checkbox" class="sticky-smart-upsell-check" aria-label="Add {{ item.title | escape }}">
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if settings.upsellEnabled and settings.upsellProductId != blank -%}
          <label class="sticky-upsell-row" for="sticky-upsell-checkbox">
            <input id="sticky-upsell-checkbox" type="checkbox" checked aria-label="Add recommended item to cart">
            <span>Add recommended item</span>
          </label>
        {%- endif -%}

        {%- if settings.showCartSummary != false -%}
          <div class="sticky-click-meta" aria-live="polite">
            <span id="sticky-cart-count">0 items</span>
            <span id="sticky-cart-subtotal">$0.00</span>
          </div>
        {%- endif -%}

        {%- if settings.enableQuantitySelector != false -%}
          <div class="sticky-qty-row" aria-label="Quantity selector">
            <button id="sticky-qty-decrease" class="sticky-qty-btn" type="button" aria-label="Decrease quantity">−</button>
            <span id="sticky-qty-value" class="sticky-qty-value">1</span>
            <button id="sticky-qty-increase" class="sticky-qty-btn" type="button" aria-label="Increase quantity">+</button>
          </div>
        {%- endif -%}

        <button id="sticky-click-btn" type="button">
          {{ settings.buttonText | default: 'Add to Cart' | escape | truncate: 50, '' }}
          <span class="sticky-price"> - {{ product.selected_or_first_available_variant.price | money_with_currency }}</span>
        </button>
      {%- else -%}
        <button id="sticky-click-btn" disabled>
          Sold Out
        </button>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}
